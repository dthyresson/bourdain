{
  "name": "bourdain",
  "version": "0.0.1",
  "description": "A CLI for exploring the recipe database",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bourdain": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "keywords": ["recipes", "cli", "cooking"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0",
    "ora": "^8.0.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/sqlite3": "^3.1.11",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sqlite3"]
  }
}

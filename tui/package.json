{
  "name": "bourdain-tui",
  "version": "0.0.1",
  "description": "A terminal UI dashboard for recipe metrics",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bourdain-dashboard": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "keywords": ["recipes", "tui", "dashboard", "cli"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ink": "^4.4.1",
    "ink-table": "^3.1.0",
    "react": "^18.2.0",
    "sqlite3": "^5.1.7",
    "sisteransi": "^1.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/sqlite3": "^3.1.11",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sqlite3"]
  }
}